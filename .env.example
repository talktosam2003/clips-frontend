# ClipCash Frontend Environment Variables
# Copy to clips-frontend/.env.local: cp .env.example clips-frontend/.env.local

# API Configuration
# Base URL for API requests in local development
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Authentication (required) ─────────────────────────────────────────────────

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple Sign In — https://developer.apple.com/account/resources/authkeys/list
APPLE_ID=your.apple.service.id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
# PEM private key; use \n for line breaks in .env.local
APPLE_PRIVATE_KEY=your-apple-private-key

# NextAuth — https://next-auth.js.org/configuration/options
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000

# Sentry error reporting — https://sentry.io → Project Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ─── Stellar Blockchain ────────────────────────────────────────────────────────

# NEXT_PUBLIC_STELLAR_NETWORK controls which Stellar network the app targets.
#
#   testnet  (default) — Horizon testnet, Friendbot funding, safe for development
#   mainnet            — Horizon mainnet, real XLM, no Friendbot
#
# NEXT_PUBLIC_STELLAR_RPC is the Soroban RPC endpoint.
# Leave blank to use the default for the selected network:
#   testnet  → https://soroban-testnet.stellar.org
#   mainnet  → https://soroban.stellar.org

NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_STELLAR_RPC=https://soroban-testnet.stellar.org

# Optional: mainnet overrides (uncomment for production)
# NEXT_PUBLIC_STELLAR_NETWORK=mainnet
# NEXT_PUBLIC_STELLAR_RPC=https://soroban.stellar.org

# Optional: Soroban NFT contract addresses
# NEXT_PUBLIC_STELLAR_NFT_CONTRACT_ID=your_testnet_contract_id_here
# NEXT_PUBLIC_STELLAR_NFT_CONTRACT_ID_MAINNET=your_mainnet_contract_id_here

# Optional: fee sponsorship public key (default: empty — sponsorship disabled)
# NEXT_PUBLIC_SPONSOR_PUBLIC_KEY=

# ─── Analytics (optional) ────────────────────────────────────────────────────

# Provider: ga4 | plausible | custom | none (default: none)
NEXT_PUBLIC_ANALYTICS_PROVIDER=none

# Optional: Google Analytics 4 — https://analytics.google.com/
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Plausible — https://plausible.io/
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=clipcash.ai

# Optional: custom analytics endpoint
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://your-analytics-api.com/events

# ─── OAuth providers (optional) ────────────────────────────────────────────────

# Twitter/X — https://developer.twitter.com/en/portal/dashboard
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# Instagram — https://developers.facebook.com/
# INSTAGRAM_CLIENT_ID=
# INSTAGRAM_CLIENT_SECRET=

# TikTok — https://developers.tiktok.com/
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=

# Optional: Sentry release/environment overrides (default: NODE_ENV / VERCEL_GIT_COMMIT_SHA)
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_RELEASE=
