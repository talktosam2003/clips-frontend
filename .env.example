# ClipCash Frontend Environment Variables

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000

# Stellar Blockchain
NEXT_PUBLIC_STELLAR_RPC=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Analytics Configuration
# Options: 'ga4', 'plausible', 'custom', 'none'
NEXT_PUBLIC_ANALYTICS_PROVIDER=none

# Google Analytics 4 (if using ga4)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Plausible Analytics (if using plausible)
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=clipcash.ai

# Custom Analytics Endpoint (if using custom)
# NEXT_PUBLIC_ANALYTICS_ENDPOINT=https://your-analytics-api.com/events
