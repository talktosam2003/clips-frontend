# Copy this file to .env.local and fill in your values.
#
# ─── Auth (required in all environments) ──────────────────────────────────────
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

APPLE_ID=your_apple_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id
# Paste the full PEM private key (replace newlines with \n if needed)
APPLE_PRIVATE_KEY=your_apple_private_key

NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# ─── API (required in production) ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ─── AI Processing Backend (required in production) ──────────────────────────
# Base URL of the AI video processing service.
# The upload route POSTs job payloads to <NEXT_PUBLIC_AI_API_URL>/jobs.
NEXT_PUBLIC_AI_API_URL=http://localhost:5000

# Shared secret sent as a Bearer token on outbound AI backend requests.
AI_BACKEND_SECRET=your_ai_backend_secret

# Secret the AI backend must include when calling /api/jobs/[id]/callback.
# Generate with: openssl rand -hex 32
AI_BACKEND_CALLBACK_SECRET=your_callback_secret

# ─── Cloud Storage (required in production) — Issue #442 ─────────────────────
# All CLOUD_STORAGE_* and AWS_* vars are required for the upload API.

# Provider: "s3" (default) | "r2" | "gcs"
CLOUD_STORAGE_PROVIDER=s3

# Bucket name (create this in your cloud console first)
CLOUD_STORAGE_BUCKET=clips-uploads

# Region (use "auto" for Cloudflare R2)
CLOUD_STORAGE_REGION=us-east-1

# Custom endpoint — required for Cloudflare R2 and GCS S3 interop.
# Leave blank for standard AWS S3.
# R2 example: https://<account-id>.r2.cloudflarestorage.com
# GCS example: https://storage.googleapis.com
CLOUD_STORAGE_ENDPOINT=

# Object key prefix (default: "uploads/")
CLOUD_STORAGE_KEY_PREFIX=uploads/

# AWS / R2 / GCS S3-interop credentials
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# ─── Virus Scanning ────────────────────────────────────────────────────────
# Virus scanning is enabled by default in production, disabled in development.
# Files are stored in quarantine/ prefix before scanning and moved only if clean.

# Scan provider: "clamav" | "virustotal" | "cloudmersive" | "disabled"
VIRUS_SCAN_PROVIDER=clamav

# Timeout for virus scans in milliseconds (default: 30000 = 30 seconds)
VIRUS_SCAN_TIMEOUT=30000

# Enable/disable scanning (default: true in production, false in development)
VIRUS_SCAN_ENABLED=true

# Quarantine prefix where files are stored before scanning (default: "uploads/quarantine/")
VIRUS_SCAN_QUARANTINE_PREFIX=uploads/quarantine/

# ClamAV configuration (required if VIRUS_SCAN_PROVIDER=clamav)
# Example for local sidecar: http://localhost:8080
# Example for remote service: https://clamav.example.com
CLAMAV_API_URL=http://localhost:8080

# VirusTotal configuration (required if VIRUS_SCAN_PROVIDER=virustotal)
# Get your API key from https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key

# Cloudmersive configuration (required if VIRUS_SCAN_PROVIDER=cloudmersive)
# Get your API key from https://www.cloudmersive.com
CLOUDMERSIVE_API_KEY=your_cloudmersive_api_key
